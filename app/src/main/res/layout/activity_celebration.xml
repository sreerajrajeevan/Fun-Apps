<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:gravity="center">

    <TextView
        android:id="@+id/celebrationEmoji"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:text="@string/celebration_emoji"
        android:textSize="50sp" />

    <TextView
        android:id="@+id/successText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/celebrationEmoji"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="20dp"
        android:text="@string/success_message"
        android:textColor="@color/my_button"
        android:textSize="24sp"
        android:textAlignment="center"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/successText"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="20dp"
        android:text="@string/celebration_emoji"
        android:textSize="50sp" />

</RelativeLayout>
